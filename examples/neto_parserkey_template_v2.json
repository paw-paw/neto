{
  "$schema": "./neto_parserkey_v2.schema.json",
  "schema_version": "neto.parser_key.v2",
  "parser_key_id": "replace_with_unique_key_id_v1",
  "key_name": "Replace with human-readable ParserKey name",
  "status": "draft",
  "runtime": {
    "minimum_neto_version": "0.1.0",
    "operator_registry_version": "neto.operators.v1",
    "required_operators": [
      "sheet.exact",
      "records.row_scan",
      "predicate.any",
      "predicate.not_empty",
      "cell.column",
      "text.to_string",
      "text.trim"
    ],
    "required_plugins": []
  },
  "tournament": {
    "name": "Replace with tournament name",
    "game": null,
    "organizer": null,
    "base_timezone": "UTC",
    "timezone_source": "parser_key",
    "season_or_edition": null
  },
  "workbook": {
    "file_type": "xlsx",
    "date_system": "auto",
    "sheet_matching_default": "exact",
    "formula_value_policy": {
      "mode": "first_available",
      "fallback_order": [
        "cached_value",
        "raw_value",
        "display_value"
      ],
      "on_missing_cached_value": "warning"
    },
    "hidden_content_policy": {
      "include_hidden_sheets": false,
      "include_hidden_rows": false,
      "include_hidden_columns": false
    }
  },
  "sources": [
    {
      "source_id": "schedule",
      "sheet_locator": {
        "op": "sheet.exact",
        "args": {
          "name": "Replace with sheet name"
        }
      },
      "value_mode": "inherit",
      "required": true,
      "description": "Primary schedule source."
    }
  ],
  "record_sets": [
    {
      "record_set_id": "main_schedule",
      "enabled": true,
      "source_id": "schedule",
      "locator": {
        "op": "records.row_scan",
        "args": {
          "start_row": 2,
          "end_row": null,
          "step": 1,
          "anchor_column": "A",
          "stop": {
            "op": "predicate.always",
            "args": {
              "mode": "end_of_used_range"
            }
          }
        }
      },
      "filter": {
        "op": "predicate.any",
        "args": {
          "predicates": [
            {
              "op": "predicate.not_empty",
              "args": {
                "value": {
                  "op": "cell.column",
                  "args": {
                    "column": "C"
                  }
                }
              }
            },
            {
              "op": "predicate.not_empty",
              "args": {
                "value": {
                  "op": "cell.column",
                  "args": {
                    "column": "D"
                  }
                }
              }
            }
          ]
        }
      },
      "context": {},
      "extractors": [],
      "fields": {
        "date": {
          "value": {
            "source": {
              "op": "cell.column",
              "args": {
                "column": "A"
              }
            },
            "transforms": [
              {
                "op": "datetime.parse_date",
                "args": {
                  "format": "auto"
                }
              }
            ],
            "fallbacks": []
          },
          "required": true,
          "on_missing": "blocking_error",
          "default": null,
          "description": "Original local event date.",
          "provenance": {
            "enabled": true,
            "include_transform_chain": true,
            "include_source_coordinates": true
          }
        },
        "time": {
          "value": {
            "source": {
              "op": "cell.column",
              "args": {
                "column": "B"
              }
            },
            "transforms": [
              {
                "op": "datetime.parse_time",
                "args": {
                  "format": "auto"
                }
              }
            ],
            "fallbacks": []
          },
          "required": true,
          "on_missing": "blocking_error",
          "default": null,
          "description": "Original local start time.",
          "provenance": {
            "enabled": true,
            "include_transform_chain": true,
            "include_source_coordinates": true
          }
        },
        "team_a": {
          "value": {
            "source": {
              "op": "cell.column",
              "args": {
                "column": "C"
              }
            },
            "transforms": [
              {
                "op": "text.to_string",
                "args": {}
              },
              {
                "op": "text.trim",
                "args": {}
              }
            ],
            "fallbacks": []
          },
          "required": true,
          "on_missing": "blocking_error",
          "default": null,
          "description": "First participant.",
          "provenance": {
            "enabled": true,
            "include_transform_chain": true,
            "include_source_coordinates": true
          }
        },
        "team_b": {
          "value": {
            "source": {
              "op": "cell.column",
              "args": {
                "column": "D"
              }
            },
            "transforms": [
              {
                "op": "text.to_string",
                "args": {}
              },
              {
                "op": "text.trim",
                "args": {}
              }
            ],
            "fallbacks": []
          },
          "required": true,
          "on_missing": "blocking_error",
          "default": null,
          "description": "Second participant.",
          "provenance": {
            "enabled": true,
            "include_transform_chain": true,
            "include_source_coordinates": true
          }
        },
        "stage": {
          "value": {
            "source": {
              "op": "cell.column",
              "args": {
                "column": "E"
              }
            },
            "transforms": [
              {
                "op": "text.to_string",
                "args": {}
              },
              {
                "op": "text.trim",
                "args": {}
              }
            ],
            "fallbacks": []
          },
          "required": false,
          "on_missing": "warning",
          "default": null,
          "description": "Tournament stage.",
          "provenance": {
            "enabled": true,
            "include_transform_chain": true,
            "include_source_coordinates": true
          }
        },
        "bo": {
          "value": {
            "source": {
              "op": "cell.column",
              "args": {
                "column": "F"
              }
            },
            "transforms": [
              {
                "op": "text.to_string",
                "args": {}
              },
              {
                "op": "text.trim",
                "args": {}
              }
            ],
            "fallbacks": []
          },
          "required": false,
          "on_missing": "warning",
          "default": null,
          "description": "Best-of format.",
          "provenance": {
            "enabled": true,
            "include_transform_chain": true,
            "include_source_coordinates": true
          }
        },
        "match_label": {
          "value": {
            "source": {
              "op": "cell.column",
              "args": {
                "column": "G"
              }
            },
            "transforms": [
              {
                "op": "text.to_string",
                "args": {}
              },
              {
                "op": "text.trim",
                "args": {}
              }
            ],
            "fallbacks": []
          },
          "required": false,
          "on_missing": "warning",
          "default": null,
          "description": "Match or series label.",
          "provenance": {
            "enabled": true,
            "include_transform_chain": true,
            "include_source_coordinates": true
          }
        }
      },
      "additional_fields": {},
      "overrides": [],
      "provenance": {
        "enabled": true,
        "include_source_coordinates": true,
        "include_transform_chain": true,
        "include_override_reason": true
      }
    }
  ],
  "normalization": {
    "strings": {
      "trim": true,
      "collapse_internal_whitespace": true,
      "replace_line_breaks_with_space": true,
      "preserve_casing": true
    },
    "datetime": {
      "precedence": [
        "start_datetime",
        "date_plus_time"
      ],
      "timezone_fallback": "tournament.base_timezone",
      "dst_policy": "iana",
      "utc_output_format": "%Y-%m-%dT%H:%M:%SZ",
      "ambiguous_time_policy": "blocking_error",
      "nonexistent_time_policy": "blocking_error"
    },
    "teams": {
      "allow_placeholders": true,
      "placeholder_values": [
        "TBD",
        "TBA"
      ],
      "placeholder_patterns": [
        "^(Winner|Loser)\\s+M\\d+$",
        "^Seed\\s+#?\\d+$",
        "^Qualifier\\s+\\d+$"
      ]
    },
    "best_of": {
      "normalize": true,
      "output_format": "BO{n}"
    }
  },
  "validation": {
    "blocking_fields": [
      "start_time_utc",
      "team_a",
      "team_b"
    ],
    "warning_fields": [
      "stage",
      "bo",
      "match_label"
    ],
    "duplicate_check": {
      "enabled": true,
      "severity": "warning",
      "fields": [
        "start_time_utc",
        "team_a",
        "team_b"
      ],
      "team_order_sensitive": true
    },
    "record_count": {
      "minimum": 1,
      "maximum": null,
      "on_violation": "blocking_error"
    },
    "custom_rules": []
  },
  "output": {
    "model": "neto.normalized_match.v1",
    "columns": [
      "date_original",
      "time_original",
      "timezone",
      "start_time_utc",
      "team_a",
      "team_b",
      "stage",
      "bo",
      "match_label",
      "row_status"
    ],
    "csv_columns": [
      "date_original",
      "time_original",
      "timezone",
      "start_time_utc",
      "team_a",
      "team_b",
      "stage",
      "bo",
      "match_label"
    ],
    "preserve_source_order": true,
    "include_provenance_in_internal_result": true,
    "sort": []
  },
  "extensions": {
    "plugins": [],
    "custom_config": {}
  },
  "metadata": {
    "created_at": "2026-07-12T00:34:30Z",
    "created_by": "NETO template",
    "updated_at": null,
    "source_files": [],
    "notes": "Universal ParserKey v2 template. Replace the sample linear record set with one or more record sets using standard operators or plugins. All ParserKeys should continue to emit neto.normalized_match.v1.",
    "tags": [
      "template",
      "universal",
      "v2"
    ]
  }
}
