      "predicate.all",
      "predicate.any",
      "predicate.not",
      "predicate.is_empty",
      "predicate.not_empty",
      "predicate.equals",
      "predicate.not_equals",
      "predicate.in",
      "predicate.matches_regex",
      "predicate.number_compare",
      "predicate.cell_style",
      "predicate.is_merged",
      "predicate.row_hidden",
      "predicate.column_hidden",
      "predicate.plugin"
    ],
    "transforms": [
      "text.to_string",
      "text.trim",
      "text.collapse_whitespace",
      "text.replace",
      "text.regex_extract",
      "text.regex_replace",
      "text.split",
      "text.substring",
