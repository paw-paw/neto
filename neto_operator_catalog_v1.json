      "datetime.convert_timezone",
      "datetime.format_date",
      "datetime.format_time",
      "datetime.format_datetime",
      "transform.plugin"
    ]
  },
  "semantic_rules": [
    "Every operator used by a ParserKey must appear in runtime.required_operators or be supplied by a required plugin.",
    "Operator argument validation is performed by the operator registry, not by the structural ParserKey JSON Schema.",
    "A record set must resolve team_a and team_b plus either start_datetime or both date and time.",
    "All record sets must emit the same normalized match model.",
    "Plugins are the final escape hatch for layouts that cannot be represented with standard operators."
  ]
}
