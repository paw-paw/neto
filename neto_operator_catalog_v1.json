      "cell.relative",
      "cell.named_range",
      "cell.merged_origin",
      "cell.nearest_non_empty",
      "cell.property",
      "context.get",
      "field.get",
      "extractor.output",
      "literal.value",
      "record.row_index",
      "record.column_index",
      "source.sheet_name",
      "lookup.exact",
      "lookup.regex",
      "lookup.index_match",
      "value.coalesce",
      "value.plugin"
    ],
    "extractors": [
      "extract.regex",
      "extract.split",
      "extract.delimited_pair",
      "extract.json",
      "extract.plugin"
    ],
    "predicates": [
